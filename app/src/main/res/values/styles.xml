<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Fullscreen, no action bar, deep-navy window background so there is
         never a white flash before the WebView paints. -->
    <style name="AppTheme" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/launch_bg</item>
        <item name="android:statusBarColor">@color/launch_bg</item>
        <item name="android:navigationBarColor">@color/launch_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentTransitions">false</item>
    </style>
</resources>
